CREATE MEMORY TABLE PUBLIC.EXPENSE(ID VARCHAR(36) NOT NULL PRIMARY KEY,ADDITIONALDETAILS VARCHAR(255),AMOUNT DOUBLE NOT NULL,CREATEDAT TIMESTAMP,DESCRIPTION VARCHAR(500),EXPENSEDATE TIMESTAMP NOT NULL,OWNERID INTEGER NOT NULL,PROOF VARCHAR(255),SCOPE VARCHAR(255) NOT NULL,STATUS BOOLEAN NOT NULL,TYPE VARCHAR(255) NOT NULL)

CREATE MEMORY TABLE PUBLIC.INVENTORY(ID VARCHAR(36) NOT NULL PRIMARY KEY,ADDITIONALDETAILS VARCHAR(255),BRAND VARCHAR(255),CATEGORY VARCHAR(255),CATEGORYTYPE VARCHAR(255),CREATED_AT TIMESTAMP,DESCRIPTION VARCHAR(255),FINGER_PRINT VARCHAR(255) NOT NULL,GSTRATE VARCHAR(255),IMAGE VARCHAR(255),INITIALPRICE DOUBLE,ITEMCODE VARCHAR(255) NOT NULL,ITEMCOLOR VARCHAR(255),ITEMCONDITION VARCHAR(255),ITEMGEN VARCHAR(255),ITEMSOURCE VARCHAR(255),MEASURETYPE VARCHAR(255),MODELNAME VARCHAR(255),OPERATINGSYSTEM VARCHAR(255),OWNERID INTEGER NOT NULL,PROCESSOR VARCHAR(255),QUANTITY INTEGER,RAM VARCHAR(255),RAMUNIT VARCHAR(255),SCREENSIZE VARCHAR(255),SELLINGPRICE DOUBLE,SERIALNUMBER VARCHAR(255),STATUS BOOLEAN NOT NULL,STORAGE VARCHAR(255),STORAGETYPE VARCHAR(255),STORAGEUNIT VARCHAR(255),UPDATED_AT TIMESTAMP,VENDORGSTNUMBER VARCHAR(255),VENDORNAME VARCHAR(255),CONSTRAINT UK1G1IWFREV9NUUYHLKNP8CJCEP UNIQUE(FINGER_PRINT),CONSTRAINT UKMLHC3ESR1LAFTA1PH5W1UK5YY UNIQUE(ITEMCODE))
